# Google Sheets Configuration
GOOGLE_CREDENTIALS_FILE=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet names (must match exactly the tab names in your spreadsheet)
ADS_SHEET_NAME=Ads
LEADS_SHEET_NAME=Leads
APPOINTMENTS_SHEET_NAME=Appointments
SALES_SHEET_NAME=Sales

# Gemini API (gratuito em aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Dashboard Settings
SHEETS_REFRESH_INTERVAL=60        # seconds between Google Sheets fetches
INSIGHTS_REFRESH_INTERVAL=300     # seconds between Claude API calls
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_DEBUG=false
PORT=5000
